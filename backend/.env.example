DATABASE_URL=sqlite:///./data/lexflow.db
CORS_ORIGINS=http://localhost:3000

# Local development storage. Production should use r2 or s3.
STORAGE_PROVIDER=local
UPLOAD_DIR=./app/uploads
MAX_UPLOAD_SIZE_BYTES=20971520

# Private S3-compatible storage (Cloudflare R2 or standard S3).
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto

LLM_PROVIDER=zhipu
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash-250414
